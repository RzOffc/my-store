# ===========================================
# FIREBASE CONFIGURATION
# Dapatkan dari: https://console.firebase.google.com
# Project Settings > Your Apps > Web App > Config
# ===========================================
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id

# ===========================================
# PAKASIR POS INTEGRATION
# Dapatkan dari: Dashboard Pakasir > Integrasi > API
# ===========================================
NEXT_PUBLIC_PAKASIR_API_URL=https://api.pakasir.com/v1
NEXT_PUBLIC_PAKASIR_OUTLET_ID=your_outlet_id
# PENTING: Variabel ini TANPA NEXT_PUBLIC agar tidak terekspos di browser
PAKASIR_API_KEY=your_pakasir_api_key
